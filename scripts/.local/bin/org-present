#!/usr/bin/env bash
# Extract markdown block from an org-roam node, and open it in presenterm.
# Features auto-update with file watching.
set -euo pipefail

# Directory containing org-roam files.
ORGROAM_DIR="${ORGROAM_DIR:-$HOME/org-roam}"

# Check for required tools:
missing=()
for cmd in fzf inotifywait presenterm; do
    if ! command -v "$cmd" &>/dev/null; then
        missing+=("$cmd")
    fi
done
if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: missing required tool(s): ${missing[*]}"
    exit 1
fi

# If a file was passed, used said file. Otherwise, pick with FZF:
if [[ $# -ge 1 ]]; then
    ORG_FILE="$(realpath "$1")"
else
    # No file given: pick one from ORGROAM_DIR via fzf.
    if [[ ! -d "$ORGROAM_DIR" ]]; then
        echo "Error: ORGROAM_DIR not found: $ORGROAM_DIR"
        exit 1
    fi
    SELECTION="$(cd "$ORGROAM_DIR" && find . -type f -name '*.org' | sed 's|^\./||' | fzf --prompt='org file> ')"
    if [[ -z "$SELECTION" ]]; then
        echo "No file selected."
        exit 1
    fi
    ORG_FILE="$(realpath "$ORGROAM_DIR/$SELECTION")"
fi

if [[ ! -f "$ORG_FILE" ]]; then
    echo "Error: file not found: $ORG_FILE"
    exit 1
fi

# temp file + cleanup:
TMPFILE="$(mktemp --tmpdir=$ORGROAM_DIR org-slides-$(date +%Y%m%d_%H%M%S)-XXXX.md)"
trap 'rm -f "$TMPFILE"' EXIT

extract_slides() {
    # Extract content between #+begin_src md and #+end_src
    awk '
        /^#\+begin_src[[:space:]]+md[[:space:]]*$/ { capture=1; next }
        /^#\+end_src[[:space:]]*$/ { if (capture) { capture=0 } next }
        capture { print }
    ' "$ORG_FILE" > "$TMPFILE"
}

# Initial extraction
extract_slides

if [[ ! -s "$TMPFILE" ]]; then
    echo "Error: no markdown slide content found in: $ORG_FILE"
    exit 1
fi

# Watch for changes, re-extracting slides on every edit.
# Watching for directory changes to prevent weird editor file-saving behaviour
# from messing with this:
WATCH_DIR="$(dirname "$ORG_FILE")"
WATCH_BASE="$(basename "$ORG_FILE")"
(
    while changed="$(inotifywait -q -e close_write,modify,moved_to,create \
        --format '%f' "$WATCH_DIR" 2>/dev/null)"; do
        if [[ "$changed" == "$WATCH_BASE" ]]; then
            extract_slides
        fi
    done
) &
WATCHER_PID=$!

# Make sure the watcher is killed when we exit.
trap 'rm -f "$TMPFILE"; kill "$WATCHER_PID" 2>/dev/null || true' EXIT

PRESENTERM_ARGS=("$TMPFILE")

# Export pdf if requested:
if [[ -n "${ORGPRESENT_PDF:-}" ]]; then
    ORG_BASE="$(basename "${ORG_FILE%.org}")"
    PDF_NAME="$(pwd)/${ORG_BASE}.pdf"
    PRESENTERM_ARGS+=(--export-pdf --output "$PDF_NAME")
fi

(cd "$ORGROAM_DIR" && presenterm "${PRESENTERM_ARGS[@]}")
